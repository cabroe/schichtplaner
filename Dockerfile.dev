FROM golang:1.24-alpine

# Install air for hot reload
RUN go install github.com/air-verse/air@latest

# Set the Current Working Directory inside the container
WORKDIR /app

# Copy go mod and sum files
COPY go.mod go.sum ./

# Download all dependencies
RUN go mod download

# Copy the source code
COPY . .

# Create empty frontend/dist directory to avoid embed errors
RUN mkdir -p frontend/dist && echo '<!DOCTYPE html><html><head><title>Dev Mode</title></head><body><h1>Development Mode - Frontend served separately</h1></body></html>' > frontend/dist/index.html

# Expose port 3000
EXPOSE 3000

# Command to run the application with hot reload
CMD ["air", "-c", ".air.toml"]
