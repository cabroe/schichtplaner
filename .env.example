# Server Configuration
SERVER_PORT=3000

# Security Configuration
# REQUIRED: Session secret for cookie encryption (min 32 characters)
SESSION_SECRET=your-super-secret-session-key-here-32-chars-minimum

# Environment
ENVIRONMENT=development

# Rate Limiting
RATE_LIMIT_PER_SECOND=20

# Production example:
# SESSION_SECRET=A9F8E7D6C5B4A3928176E5D4C3B2A1908F7E6D5C4B3A2918
# ENVIRONMENT=production
# RATE_LIMIT_PER_SECOND=50
